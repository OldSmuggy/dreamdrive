# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Exchange Rate API (https://openexchangerates.org)
OPEN_EXCHANGE_RATES_APP_ID=your_app_id_here

# Scraper credentials (server-only)
NINJA_LOGIN_ID=your_ninja_login
NINJA_PASSWORD=your_ninja_password

# App
NEXT_PUBLIC_APP_URL=https://barecamper.com

# Google Analytics & Search Console
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code
NEXT_PUBLIC_AUCTION_DAY=4
# 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
NEXT_PUBLIC_AUCTION_HOUR_JST=10
# hour in JST when Thursday auction closes

# Figma
FIGMA_API_TOKEN=your_figma_personal_access_token
